# =============================================================================
# RENDER DASHBOARD — Backend service (presenter-global) Environment Variables
# Your laptop .env is NOT used on Render. Set these in the Render UI.
# =============================================================================

NODE_ENV=production

# 1) Create PostgreSQL on Render → Link to backend service (auto-fills DATABASE_URL)
#    Or paste manually: Internal Database URL (host ends with .render.com, NOT localhost)
DATABASE_URL=postgresql://user:password@dpg-xxxxx-a.oregon-postgres.render.com/dbname

# 2) Create Redis / Key Value on Render → Link to backend (auto-fills REDIS_URL)
#    Use Internal URL. Upstash-style URLs start with rediss://
REDIS_URL=redis://red-xxxxx:6379
# REDIS_URL=rediss://default:token@host.upstash.io:6379

CLIENT_URL=https://presenter-mobile.onrender.com
MOBILE_URL=https://presenter-mobile.onrender.com

JWT_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-different-long-random-string

# PORT — do not set; Render injects it automatically

# =============================================================================
# RENDER DASHBOARD — Mobile service (presenter-mobile)
# =============================================================================
NEXT_PUBLIC_BACKEND_URL=https://presenter-global.onrender.com
# Redeploy mobile after any change to NEXT_PUBLIC_*

# =============================================================================
# After deploy, health should show:
#   "db": "connected"
#   "redis": "connected"
#   "config": { "databaseUrlConfigured": true, "redisUrlConfigured": true }
# =============================================================================
