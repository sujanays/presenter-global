# =========================================================================
# GLOBAL PRESENTER ENVS TEMPLATE
# =========================================================================

# Node environment parameters
PORT=3001
NODE_ENV=development

# Postgres DB Credentials
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/presenter

# Redis scaling adapter (Optional for local memory, Required for horizontal scaling)
REDIS_URL=redis://localhost:6379

# Client/Frontend URLs for CORS mapping
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Cryptography and session tokens secrets
JWT_SECRET=your_jwt_signing_token_key_change_me
JWT_REFRESH_SECRET=your_refresh_signing_token_key_change_me
