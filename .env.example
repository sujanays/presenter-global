# =========================================================================
# LAPTOP ONLY — copy to .env when running: npm run desktop:dev
# Backend + mobile run on Render (see render.env.example for Render dashboard)
# =========================================================================

# Electron desktop agent (required locally)
BACKEND_URL=https://presenter-global.onrender.com
MOBILE_URL=https://presenter-mobile.onrender.com

# Used only if you run "npm run mobile:dev" locally (optional)
NEXT_PUBLIC_BACKEND_URL=https://presenter-global.onrender.com

# ---------------------------------------------------------------------------
# Do NOT put these on laptop for cloud-only testing — set on Render backend:
#   DATABASE_URL, REDIS_URL, JWT_SECRET, JWT_REFRESH_SECRET, CLIENT_URL
# See render.env.example
# ---------------------------------------------------------------------------

# --- Only if you also run backend locally (npm run backend:dev) ---
# PORT=3001
# NODE_ENV=development
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/presenter
# REDIS_URL=redis://localhost:6379
# JWT_SECRET=local-dev-only-secret
# JWT_REFRESH_SECRET=local-dev-only-refresh-secret
# CLIENT_URL=http://localhost:3000
